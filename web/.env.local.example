# OpenAI
# Paste your real key into .env.local as OPENAI_API_KEY=sk-...
OPENAI_API_KEY=

# Optional: override the vehicle-analysis model used by the future OpenAI service.
OPENAI_VEHICLE_MODEL=

# Supabase public browser config, used later by Auth, Postgres, and Storage clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only service role key for future backend routes.
# Never expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: storage bucket name for uploaded vehicle images.
SUPABASE_VEHICLE_IMAGES_BUCKET=
